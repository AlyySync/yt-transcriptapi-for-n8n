# Copy this file to ".env" and fill in the values you need:
#   cp .env.example .env
#
# The .env file is git-ignored, so your real credentials never get pushed.

# ---------------------------------------------------------------------------
# PROXY (optional)
# ---------------------------------------------------------------------------
# Leave ALL of these blank to connect directly with the server's own IP.
# The proxy is only used when ALL FOUR values are filled in.
# Fill them in only if the server gets an "IpBlocked" / "RequestBlocked" error.
#
# Example (IPRoyal):
#   PROXY_IP=geo.iproyal.com
#   PROXY_PORT=12321
#   PROXY_USER=your_proxy_username
#   PROXY_PASS=your_proxy_password
PROXY_IP=
PROXY_PORT=
PROXY_USER=
PROXY_PASS=

# ---------------------------------------------------------------------------
# LOGGING
# ---------------------------------------------------------------------------
# LOG_LEVEL: INFO for normal use, DEBUG for very detailed troubleshooting.
LOG_LEVEL=INFO

# LOG_RETENTION_DAYS: how many days of log files to keep.
# Logs rotate daily; anything older than this is deleted automatically.
LOG_RETENTION_DAYS=7

# LOG_DIR: folder where log files (app.log, error.log) are written.
LOG_DIR=logs